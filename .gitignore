# ============================================================================
# AI Dev Pipeline - Runtime Files
# ============================================================================

# Task files (user-generated)
.harness/tasks/pending/*.json
.harness/tasks/completed/

# Task index (auto-generated)
.harness/task-index.json

# CLI sessions
.harness/cli-io/sessions/

# Logs
.harness/logs/
*.log

# Automation state
.harness/.automation_retries/
.harness/.automation_skip/
.harness/.automation_timeouts/

# Artifacts (generated outputs)
.harness/artifacts/

# Reports
.harness/reports/

# Environment variables (may contain secrets)
.harness/.env
.env

# ============================================================================
# Project-specific ignores
# ============================================================================

# Test coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebooks
.ipynb_checkpoints

# pyenv
.python-version

# Backup files
*.backup
*.bak
*.old