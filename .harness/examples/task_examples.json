  "usage_guide": {
    "description": "如何使用这些示例创建任务",
    "methods": [
      {
        "method": "手动创建",
        "steps": [
          "1. 从 examples 中找到匹配的任务类型",
          "2. 复制 acceptance 数组",
          "3. 根据实际情况修改文件路径和验证项",
          "4. 使用 add_task.py 创建任务"
        ],
        "example": "python3 .harness/scripts/add_task.py --id FE_Component_002 --desc '创建按钮组件' --acceptance 'src/components/Button/Button.tsx 存在' '支持 variant prop' 'npm test 通过'"
      },
      {
        "method": "模板创建（未来实现）",
        "steps": [
          "1. 指定 --template 参数",
          "2. 系统自动填充验收标准",
          "3. 用户微调具体内容"
        ],
        "example": "python3 .harness/scripts/add_task.py --template component --id FE_Component_002 --desc '创建按钮组件'"
      }
    ]
  },

  "customization": {
    "description": "如何自定义验收标准",
    "tips": [
      "验收标准应该具体、可验证、可测试",
      "使用明确的文件路径（相对于项目根目录）",
      "包含功能验证、测试验证、代码质量验证",
      "避免模糊的描述，如'代码质量好' → 改为'npm run lint 通过'",
      "验收标准数量建议 5-10 条，不要过多"
    ]
  }
