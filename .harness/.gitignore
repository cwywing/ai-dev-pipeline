# Harness 内部忽略文件
# 这些文件不应该被提交到版本控制

# ============================================================================
# 单文件存储系统 - 索引和备份
# ============================================================================
task-index.json.backup*
task-index.json.before_

# ============================================================================
# 临时文件和状态（运行时）
# ============================================================================
.automation_retries/
.automation_skip/
.automation_timeouts/

# ============================================================================
# 日志文件（已在 logs/ 目录中归档）
# ============================================================================
*.log
automation_*.log


# ============================================================================
# CLI 会话管理
# ============================================================================
cli-io/sessions/

# ============================================================================
# 临时修复脚本和文件
# ============================================================================
scripts/fix-formrequest.php
*.tmp

# ============================================================================
# 系统文件
# ============================================================================
.DS_Store
Thumbs.db

# ============================================================================
# 历史备份文件（旧系统遗留，用于清理）
# ============================================================================
backups/
task.json.backup*
task.json.before_
task.json.pre-*

# ============================================================================
# 测试和报告文件（临时）
# ============================================================================
test-reports/
coverage.xml
coverage-report/

# ============================================================================
# 任务产物（动态生成）
# ============================================================================
artifacts/*.json

# ============================================================================
# Python Bytecode Cache
# ============================================================================
__pycache__/
scripts/__pycache__/
windows/__pycache__/
windows/scripts/__pycache__/
*.py[cod]
*$py.class
