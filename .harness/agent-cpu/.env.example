# ═══════════════════════════════════════════════════════════════
#                   LLM API 配置（必填）
# ═══════════════════════════════════════════════════════════════
# 方式一：官方 Anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# 方式二：智谱AI / 兼容 Provider（如 bigmodel.cn）
ANTHROPIC_AUTH_TOKEN=your_token_here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_AUTH_HEADER=Authorization

# 默认模型名称
# 智谱AI: glm-4.5-Air, glm-5, glm-4, etc.
# Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514, etc.
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5

# 请求超时（毫秒），默认 300000 (5分钟)
API_TIMEOUT_MS=300000

# ═══════════════════════════════════════════════════════════════
#                   Agent CPU 运行配置
# ═══════════════════════════════════════════════════════════════
# 自愈引擎最大重试次数
MAX_RETRIES=3

# 知识库自动同步（true/false）
AUTO_SYNC_KB=true

# 沙箱模式（false 避免 Node.js vm 模块导入问题）
SANDBOX=false

# ═══════════════════════════════════════════════════════════════
#                   Harness 自动化配置（可选）
# ═══════════════════════════════════════════════════════════════
ENABLE_AUTO_VALIDATION=false
PERMISSION_MODE=bypassPermissions
BASE_SILENCE_TIMEOUT=60
MAX_SILENCE_TIMEOUT=180
LOOP_SLEEP=2
MAX_RETRIES=3
