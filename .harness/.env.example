# 禁用自动验证功能（防止 SIM_Test_Verify_001 过早执行）
ENABLE_AUTO_VALIDATION=false

# ═══════════════════════════════════════════════════════════════
#                   工作区隔离配置
# ═══════════════════════════════════════════════════════════════
# Agent 读写业务代码的工作目录
# 不配置时默认使用引擎根目录下的 sandbox/ 子目录
# 配置示例: TARGET_WORKSPACE=/path/to/your/target/project
# TARGET_WORKSPACE=

# ═══════════════════════════════════════════════════════════════
#                   Harness 自动化配置
# ═══════════════════════════════════════════════════════════════
# 使用完全绕过权限模式，允许 Agent 执行命令
PERMISSION_MODE=bypassPermissions

# ═══════════════════════════════════════════════════════════════
#                   超时优化配置（性能优先）
# ═══════════════════════════════════════════════════════════════
# 基础活性超时（无输出检测）- 降低到 60 秒提升响应速度
BASE_SILENCE_TIMEOUT=60

# 最大活性超时 - 降低到 180 秒防止长时间卡死
MAX_SILENCE_TIMEOUT=180

# 超时递增因子 - 更激进的递增策略
TIMEOUT_BACKOFF_FACTOR=1.3

# 最大超时重试次数
MAX_TIMEOUT_RETRIES=3

# 循环间隔（秒）- 降低到 2 秒提升吞吐
LOOP_SLEEP=2

# 最大逻辑重试次数
MAX_RETRIES=3
